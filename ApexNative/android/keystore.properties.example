# Release signing config for Apex (Android).
#
# 1. Copy this file to `keystore.properties` (same folder). That copy is
#    git-ignored and must NEVER be committed.
# 2. Generate your keystore (see README / instructions) and fill in the
#    values below.
# 3. Store paths are relative to the `android/` folder.
#
# If keystore.properties is absent, release builds fall back to the debug key.

APEX_UPLOAD_STORE_FILE=apex-release.jks
APEX_UPLOAD_KEY_ALIAS=apex
APEX_UPLOAD_STORE_PASSWORD=change-me
APEX_UPLOAD_KEY_PASSWORD=change-me
